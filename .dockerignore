# Build-context excludes for all service images (every service uses `context: .`).
# Keep source code (data/, models/, api/, dashboard/, monitoring/, tests/, infra/,
# data/sample/); drop VCS, virtualenvs, caches, generated medallion data, and secrets.

# VCS
.git/
.gitignore

# Python virtualenvs & caches
.venv/
venv/
env/
__pycache__/
*.py[cod]
*.egg-info/
.eggs/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
.coverage.*
htmlcov/

# Generated medallion data — regenerated from raw sources, and mounted live at
# runtime via `./data:/opt/project/data`, so it never needs to be in the image.
data/bronze/
data/silver/
data/gold/

# Model artifacts (regenerated by training)
models/artifacts/
mlruns/
mlartifacts/
*.pkl
*.joblib
*.pt
*.bin
*.safetensors
*.onnx

# Secrets — provided at runtime via `env_file: .env`, never baked into an image.
.env

# Local docker bind-mount volumes
pg_data/
minio_data/

# Airflow local state
airflow/logs/
airflow/airflow.db

# Editor / OS
.cursor/
.idea/
.vscode/
.DS_Store
Thumbs.db
*.swp
*.swo

# Logs
*.log
logs/

# Exploration (not needed in any image)
notebooks/

# Big raw dataset (lives outside the repo, but guard anyway)
Malaysia Restaurant Review Datasets/
