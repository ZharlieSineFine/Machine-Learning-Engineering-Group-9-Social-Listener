# Remote / shared-host .env  —  copy to .env ON THE SERVER (cp infra/remote.env.example .env)
#
# Everything binds to 127.0.0.1 so it never clashes with other projects on the box;
# your reverse proxy fronts the dashboard. Pick host ports that are free on the server
# (the offsets below are just suggestions — change any that collide).

# --- Stack isolation (volumes/networks become brewleaf_*) ---
COMPOSE_PROJECT_NAME=brewleaf

# --- Host port publishing (shared host) ---
# Bind to loopback only; the reverse proxy reaches the dashboard on 127.0.0.1.
BIND_HOST=127.0.0.1
POSTGRES_HOST_PORT=55432
MINIO_API_PORT=59000
MINIO_CONSOLE_PORT=59001
MLFLOW_HOST_PORT=55001
AIRFLOW_HOST_PORT=58080
API_HOST_PORT=58000
# The dashboard your proxy forwards to: 127.0.0.1:58501
DASHBOARD_HOST_PORT=58501

# --- Postgres (IN-CONTAINER addressing — leave HOST/PORT as the service alias) ---
POSTGRES_USER=mlops
POSTGRES_PASSWORD=change-me-strong          # CHANGE on a real server
POSTGRES_DB=sentiment
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# --- MinIO (S3-compatible) ---
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=change-me-strong      # CHANGE on a real server
MLFLOW_S3_ENDPOINT_URL=http://minio:9000

# --- MLflow (in-network alias; host access is via the tunnel on MLFLOW_HOST_PORT) ---
MLFLOW_TRACKING_URI=http://mlflow:5000

# --- Airflow ---
AIRFLOW_ADMIN_USER=airflow
AIRFLOW_ADMIN_PASSWORD=change-me-strong     # CHANGE on a real server

# --- Model serving ---
MODEL_NAME=sentiment-baseline
MODEL_STAGE=Production
SHADOW_MODEL_NAME=sentiment-baseline
SHADOW_MODEL_STAGE=Staging
SHADOW_SCORE_LOOKBACK_HOURS=6
LOG_PREDICTIONS=1
ADMIN_TOKEN=
