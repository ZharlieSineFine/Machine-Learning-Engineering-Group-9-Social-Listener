# --- Postgres ---
POSTGRES_USER=mlops
POSTGRES_PASSWORD=mlops
POSTGRES_DB=sentiment
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# --- MinIO (S3-compatible) ---
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin
MLFLOW_S3_ENDPOINT_URL=http://minio:9000

# --- MLflow ---
# From inside the docker network (api, airflow, dashboard): use service alias.
MLFLOW_TRACKING_URI=http://mlflow:5000
# From your host (browser, host-side pytest): http://localhost:5001
# (we map host 5001 -> container 5000 to avoid macOS AirPlay on port 5000)

# --- Airflow ---
AIRFLOW_ADMIN_USER=airflow
AIRFLOW_ADMIN_PASSWORD=airflow

# --- Raw review datasets (Docker volume sources) ---
# Host paths mounted into data-pipeline + Airflow (see docker-compose.yml).
# Defaults assume the multi-root workspace layout (sibling Yelp_JSON / TripAdvisor folders).
YELP_DATA_HOST=../../Yelp_JSON
TRIPADVISOR_DATA_HOST=../../TripAdvisor_data_cleaned.csv

# --- Monitoring / drift ---
# Per-column PSI threshold: a column counts as drifted when its Population
# Stability Index exceeds this (applies to features AND the label). 0.25 is the
# classic "significant shift" band. Drift is pure per-column — one column over
# this is enough to flag drift and (in the cycle gate) block promotion.
DRIFT_PSI_THRESHOLD=0.25
# Legacy share-of-drifted-columns value: recorded + shown on the dashboard gauge,
# but no longer gates anything.
# DRIFT_THRESHOLD=0.3
# Performance guards in the promotion gate (drops that block Staging -> Production):
# DRIFT_F1_DROP_THRESHOLD=0.03
# DRIFT_RECALL_NEG_DROP_THRESHOLD=0.05

# --- Model serving ---
# Phase 1: sklearn baseline
MODEL_NAME=sentiment-baseline
# Phase 2: switch to transformer
# MODEL_NAME=sentiment-distilbert
MODEL_STAGE=Production
# Token required by POST /reload. Leave UNSET in prod to disable the endpoint.
# Set to a long random string for staging where teams trigger reloads manually.
ADMIN_TOKEN=
